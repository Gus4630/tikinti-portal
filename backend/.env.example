# Backend secrets — injected into the spring-boot container only
# Copy to backend/.env and fill in real values. Never commit backend/.env.

DB_URL=jdbc:postgresql://postgres:5432/expenses
DB_USER=tikinti_user
DB_PASSWORD=changeme_db_password

JWT_ACCESS_SECRET=changeme_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=changeme_refresh_secret_min_32_chars_long

GEMINI_API_KEY=changeme_gemini_api_key

RABBIT_HOST=rabbitmq
RABBIT_PORT=5672
RABBIT_USERNAME=tikinti_rabbit
RABBIT_PASSWORD=changeme_rabbit_password

CBAR_BASE_URL=https://cbar.az

# Optional — only if using Cloudflare R2 instead of local volume
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=
# R2_ENDPOINT=
